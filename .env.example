SERPER_API_KEY=
# LLM_API_KEY: works for any OpenAI-compatible provider (OpenAI, GLM, DeepSeek, ...)
LLM_API_KEY=
# Override base_url to use non-OpenAI provider. Examples:
#   GLM:      https://open.bigmodel.cn/api/paas/v4/
#   DeepSeek: https://api.deepseek.com/v1
LLM_BASE_URL=
# Model name. Examples: gpt-4o-mini, glm-4-flash, glm-4-air, deepseek-chat
LLM_MODEL=

# Zhipu/BigModel image generation for Redvia website image tests.
# Do not commit real keys. Put the real value in .env only.
ZHIPUAI_API_KEY=
ZHIPU_IMAGE_MODEL=cogview-4-250304

# Outlook SMTP for send_outreach.py. Use an Outlook App Password, not the account login password.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redvia first-party tracking for send_outreach.py.
# TRACKING_WORKER_URL is the deployed Worker/site origin, for example https://redvia.com.
TRACKING_WORKER_URL=
TRACKING_ADMIN_SECRET=
TRACKING_CAMPAIGN_ID=
TRACKING_DEFAULT_DESTINATION_PATH=
TRACKING_PRODUCT_SLUG=
TRACKING_CREATE_TOKENS_IN_DRY_RUN=0

# webUI ingest secret used by Cloudflare Worker scheduled sync.
# Must match the Worker ECS_API_SECRET.
WEB_TRACKING_INGEST_SECRET=

# Cloudflare Worker secrets/vars. Set these with `wrangler secret put`,
# not in committed files, for production deployments.
ADMIN_API_SECRET=
IP_HASH_SALT=
ECS_API_SECRET=
ECS_WEBHOOK_URL=
